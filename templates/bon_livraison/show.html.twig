{% extends 'base.html.twig' %}

{% block title %}{{ bon_livraison.reference }} - Bon de livraison - BBC Commercial{% endblock %}

{% block content %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3">
                <i class="fas fa-truck"></i> 
                {{ bon_livraison.reference }}
            </h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_bon_livraison_index') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
            {% if bon_livraison.canBeEdited() %}
            <a href="{{ path('app_bon_livraison_edit', {'id': bon_livraison.id}) }}" class="btn btn-warning">
                <i class="fas fa-edit"></i> Modifier
            </a>
            {% endif %}
            {% if not bon_livraison.isInvoiced() and bon_livraison.status != 'CANCELLED' %}
            <form method="post" action="{{ path('app_bon_livraison_cancel', {'id': bon_livraison.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr d\'annuler ce bon de livraison ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ bon_livraison.id) }}">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-ban"></i> Annuler
                </button>
            </form>
            {% endif %}
        </div>
    </div>

    <!-- Delivery Note Info Card -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Informations</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="text-muted">Statut</label>
                            <p class="mb-0"><strong>
                                <span class="badge 
                                    {% if bon_livraison.status == 'DRAFT' %}bg-warning
                                    {% elseif bon_livraison.status == 'VALIDATED' %}bg-success
                                    {% elseif bon_livraison.status == 'CANCELLED' %}bg-danger{% endif %}">
                                    {{ bon_livraison.status == 'DRAFT' ? 'Brouillon' : 
                                       bon_livraison.status == 'VALIDATED' ? 'Validé' : 
                                       bon_livraison.status == 'CANCELLED' ? 'Annulé' : bon_livraison.status }}
                                </span>
                            </strong></p>
                        </div>
                        <div class="col-6">
                            <label class="text-muted">Facturé</label>
                            <p class="mb-0"><strong>
                                {% if bon_livraison.isInvoiced() %}
                                    <span class="badge bg-success">Oui</span>
                                {% else %}
                                    <span class="badge bg-secondary">Non</span>
                                {% endif %}
                            </strong></p>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="text-muted">Créé par</label>
                            <p class="mb-0"><strong>{{ bon_livraison.createdBy.name }}</strong></p>
                        </div>
                        <div class="col-6">
                            <label class="text-muted">Date de création</label>
                            <p class="mb-0"><strong>{{ bon_livraison.createdAt|date('d/m/Y H:i') }}</strong></p>
                        </div>
                    </div>
                    {% if bon_livraison.cancelledAt %}
                    <div class="row">
                        <div class="col-12">
                            <label class="text-muted">Date d'annulation</label>
                            <p class="mb-0"><strong>{{ bon_livraison.cancelledAt|date('d/m/Y H:i') }}</strong></p>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Bon de commande</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="text-muted">Référence</label>
                        <p class="mb-0">
                            <a href="{{ path('app_bon_commande_show', {'id': bon_livraison.bonCommande.id}) }}" class="text-decoration-none">
                                <strong>{{ bon_livraison.bonCommande.reference }}</strong>
                            </a>
                        </p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted">Client</label>
                        <p class="mb-0"><strong>{{ bon_livraison.bonCommande.client.name }}</strong></p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted">Code Client</label>
                        <p class="mb-0"><strong>{{ bon_livraison.bonCommande.client.client_code }}</strong></p>
                    </div>
                    {% if bon_livraison.facture %}
                    <div>
                        <label class="text-muted">Facture</label>
                        <p class="mb-0">
                            <a href="{{ path('app_facture_show', {'id': bon_livraison.facture.id}) }}" class="text-decoration-none">
                                <strong>{{ bon_livraison.facture.reference }}</strong>
                            </a>
                        </p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Delivery Items Table -->
    <div class="card">
        <div class="card-header bg-light">
            <h5 class="card-title mb-0">Articles livrés</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Article</th>
                        <th class="text-center">Commandé</th>
                        <th class="text-center">Livré (ce bon)</th>
                        <th class="text-end">Prix unitaire</th>
                        <th class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    {% for deliveryItem in bon_livraison.bonLivraisonItems %}
                    <tr>
                        <td>{{ deliveryItem.bonCommandeItem.article.designation }}</td>
                        <td class="text-center">{{ deliveryItem.bonCommandeItem.quantity }}</td>
                        <td class="text-center">{{ deliveryItem.quantityDelivered }}</td>
                        <td class="text-end">{{ deliveryItem.bonCommandeItem.unitPriceSnapshot|number_format(3, '.', ',') }}</td>
                        <td class="text-end">
                            {{ (deliveryItem.quantityDelivered * deliveryItem.bonCommandeItem.unitPriceSnapshot)|number_format(3, '.', ',') }}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
