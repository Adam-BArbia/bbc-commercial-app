{% extends 'base.html.twig' %}

{% block title %}Bons de livraison - BBC Commercial{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3">
                <i class="fas fa-truck"></i> Bons de livraison
            </h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_bon_livraison_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Nouveau bon de livraison
            </a>
        </div>
    </div>

    <!-- Search and Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <input type="text" name="search" class="form-control" 
                        placeholder="Rechercher par référence, commande ou client..."
                        value="{{ search_query }}">
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select">
                        <option value="">--- Tous les statuts ---</option>
                        <option value="DRAFT" {% if status_filter == 'DRAFT' %}selected{% endif %}>Brouillon</option>
                        <option value="VALIDATED" {% if status_filter == 'VALIDATED' %}selected{% endif %}>Validé</option>
                        <option value="CANCELLED" {% if status_filter == 'CANCELLED' %}selected{% endif %}>Annulé</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-secondary w-100">
                        <i class="fas fa-search"></i> Rechercher
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delivery Notes Table -->
    {% if delivery_notes|length > 0 %}
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Référence</th>
                    <th>Commande</th>
                    <th>Client</th>
                    <th>Statut</th>
                    <th>Date de création</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for delivery in delivery_notes %}
                {% set deliveryClientName = delivery.bonCommande.clientSnapshot.name|default(delivery.bonCommande.client ? delivery.bonCommande.client.name : 'Client inconnu') %}
                <tr>
                    <td><strong>{{ delivery.reference }}</strong></td>
                    <td>{{ delivery.bonCommande.reference }}</td>
                    <td>{{ deliveryClientName }}</td>
                    <td>
                        <span class="badge 
                            {% if delivery.status == 'DRAFT' %}bg-warning
                            {% elseif delivery.status == 'VALIDATED' %}bg-success
                            {% elseif delivery.status == 'CANCELLED' %}bg-danger{% endif %}">
                            {{ delivery.status == 'DRAFT' ? 'Brouillon' : 
                               delivery.status == 'VALIDATED' ? 'Validé' : 
                               delivery.status == 'CANCELLED' ? 'Annulé' : delivery.status }}
                        </span>
                    </td>
                    <td>{{ delivery.createdAt|date('d/m/Y H:i') }}</td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm" role="group">
                            <a href="{{ path('app_bon_livraison_show', {'id': delivery.id}) }}" 
                               class="btn btn-outline-secondary" title="Voir">
                                <i class="bi bi-eye"></i>
                            </a>
                            {% if delivery.canBeEdited() %}
                            <a href="{{ path('app_bon_livraison_edit', {'id': delivery.id}) }}" 
                               class="btn btn-outline-primary" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <i class="fas fa-info-circle"></i> Aucun bon de livraison trouvé.
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">Bons de commande disponibles pour livraison</h5>
        </div>
        <div class="card-body">
            {% if available_orders|length > 0 %}
                <ul class="list-group list-group-flush">
                    {% for order in available_orders %}
                        {% set orderClientName = order.clientSnapshot.name|default(order.client ? order.client.name : 'Client inconnu') %}
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>{{ order.reference }}</strong>
                                <span class="text-muted">- {{ orderClientName }}</span>
                            </div>
                            <span class="badge bg-secondary">{{ order.status }}</span>
                        </li>
                    {% endfor %}
                </ul>
                <div class="mt-3 text-end">
                    <a href="{{ path('app_bon_livraison_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Créer un bon de livraison
                    </a>
                </div>
            {% else %}
                <p class="text-muted mb-0">Aucun bon de commande disponible. Créez d'abord un bon de commande.</p>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
