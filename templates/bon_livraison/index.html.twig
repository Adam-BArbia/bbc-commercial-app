{% extends 'base.html.twig' %}

{% block title %}{{ 'delivery.title'|trans }} - BBC Commercial{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3">
                <i class="fas fa-truck"></i> {{ 'delivery.title'|trans }}
            </h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_bon_livraison_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> {{ 'delivery.new'|trans }}
            </a>
        </div>
    </div>

    <!-- Search and Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="search" class="form-control"
                        placeholder="{{ 'delivery.search_placeholder'|trans }}"
                        value="{{ search_query }}">
                </div>
                <div class="col-md-2">
                    <select name="status" class="form-select">
                        <option value="">--- {{ 'common.all_statuses'|trans }} ---</option>
                        <option value="DRAFT" {% if status_filter == 'DRAFT' %}selected{% endif %}>{{ 'status.draft'|trans }}</option>
                        <option value="VALIDATED" {% if status_filter == 'VALIDATED' %}selected{% endif %}>{{ 'status.validated'|trans }}</option>
                        <option value="CANCELLED" {% if status_filter == 'CANCELLED' %}selected{% endif %}>{{ 'status.cancelled'|trans }}</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="date" name="date_from" class="form-control" value="{{ date_from }}" placeholder="{{ 'common.date_from'|trans }}">
                </div>
                <div class="col-md-2">
                    <input type="date" name="date_to" class="form-control" value="{{ date_to }}" placeholder="{{ 'common.date_to'|trans }}">
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-outline-secondary flex-grow-1">
                        <i class="fas fa-search"></i> {{ 'common.filter'|trans }}
                    </button>
                    {% if search_query != '' or status_filter != '' or date_from != '' or date_to != '' %}
                    <a href="{{ path('app_bon_livraison_index') }}" class="btn btn-outline-secondary" title="{{ 'common.reset'|trans }}">
                        <i class="bi bi-x-circle"></i>
                    </a>
                    {% endif %}
                </div>
            </form>
        </div>
    </div>

    <!-- Delivery Notes Table -->
    {% if delivery_notes|length > 0 %}
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>{{ 'delivery.col_reference'|trans }}</th>
                    <th>{{ 'delivery.col_order'|trans }}</th>
                    <th>{{ 'delivery.col_client'|trans }}</th>
                    <th>{{ 'common.status'|trans }}</th>
                    <th>{{ 'delivery.col_date'|trans }}</th>
                    <th class="text-center">{{ 'common.actions'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for delivery in delivery_notes %}
                {% set deliveryClientName = delivery.bonCommande.clientSnapshot.name|default(delivery.bonCommande.client ? delivery.bonCommande.client.name : '—') %}
                <tr>
                    <td><strong>{{ delivery.reference }}</strong></td>
                    <td>{{ delivery.bonCommande.reference }}</td>
                    <td>{{ deliveryClientName }}</td>
                    <td>
                        <span class="badge 
                            {% if delivery.status == 'DRAFT' %}bg-warning
                            {% elseif delivery.status == 'VALIDATED' %}bg-success
                            {% elseif delivery.status == 'CANCELLED' %}bg-danger{% endif %}">
                            {% if delivery.status == 'DRAFT' %}{{ 'status.draft'|trans }}
                            {% elseif delivery.status == 'VALIDATED' %}{{ 'status.validated'|trans }}
                            {% elseif delivery.status == 'CANCELLED' %}{{ 'status.cancelled'|trans }}
                            {% else %}{{ delivery.status }}{% endif %}
                        </span>
                    </td>
                    <td>{{ delivery.createdAt|date('d/m/Y H:i') }}</td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm" role="group">
                            <a href="{{ path('app_bon_livraison_show', {'id': delivery.id}) }}" 
                               class="btn btn-outline-secondary" title="{{ 'common.see_all'|trans }}">
                                <i class="bi bi-eye"></i>
                            </a>
                            {% if delivery.canBeEdited() %}
                            <a href="{{ path('app_bon_livraison_edit', {'id': delivery.id}) }}" 
                               class="btn btn-outline-primary" title="{{ 'common.edit'|trans }}">
                                <i class="bi bi-pencil"></i>
                            </a>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <i class="fas fa-info-circle"></i> {{ 'delivery.no_found_info'|trans }}
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">{{ 'delivery.available_orders_title'|trans }}</h5>
        </div>
        <div class="card-body">
            {% if available_orders|length > 0 %}
                <ul class="list-group list-group-flush">
                    {% for order in available_orders %}
                        {% set orderClientName = order.clientSnapshot.name|default(order.client ? order.client.name : '—') %}
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>{{ order.reference }}</strong>
                                <span class="text-muted">- {{ orderClientName }}</span>
                            </div>
                            <span class="badge bg-secondary">{{ order.status }}</span>
                        </li>
                    {% endfor %}
                </ul>
                <div class="mt-3 text-end">
                    <a href="{{ path('app_bon_livraison_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus"></i> {{ 'delivery.create_btn'|trans }}
                    </a>
                </div>
            {% else %}
                <p class="text-muted mb-0">{{ 'delivery.no_orders_hint'|trans }}</p>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
