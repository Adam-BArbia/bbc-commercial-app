{% extends 'base.html.twig' %}

{% block title %}Modifier {{ bon_livraison.reference }} - BBC Commercial{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h1 class="h3 mb-4">
                <i class="fas fa-edit"></i> Modifier {{ bon_livraison.reference }}
            </h1>

            <div class="card">
                <div class="card-body">
                    <form method="post" id="edit-form">
                        <!-- Order Info (Read-only) -->
                        <div class="alert alert-info">
                            <strong>Bon de commande:</strong> {{ bon_commande.reference }} - 
                            <strong>Client:</strong> {{ bon_commande.clientSnapshot.name|default(bon_commande.client ? bon_commande.client.name : '-') }}
                        </div>

                        <!-- Delivery Items Table -->
                        <h5 class="mb-3">Articles à livrer</h5>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Article</th>
                                        <th class="text-center">Commandé</th>
                                        <th class="text-center">Déjà livré</th>
                                        <th class="text-center">Restant</th>
                                        <th class="text-center">À livrer (ce bon)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for orderItem in bon_commande.bonCommandeItems %}
                                    {# Calculate delivered quantity EXCLUDING current BL being edited #}
                                    {% set currentItemDelivery = bon_livraison.bonLivraisonItems.filter(item => item.bonCommandeItem.id == orderItem.id).first() %}
                                    {% set currentQty = currentItemDelivery ? currentItemDelivery.quantityDelivered : 0 %}
                                    {% set totalDelivered = orderItem.deliveredQuantity %}
                                    {% set deliveredExcludingThis = totalDelivered - currentQty %}
                                    {% set remainingQty = orderItem.quantity - deliveredExcludingThis %}
                                    <tr>
                                        <td>{{ orderItem.article.designation }}</td>
                                        <td class="text-center">{{ orderItem.quantity }}</td>
                                        <td class="text-center">{{ deliveredExcludingThis|number_format(2, '.', '') }}</td>
                                        <td class="text-center">{{ remainingQty|number_format(2, '.', '') }}</td>
                                        <td class="text-center">
                                            <input type="number" name="delivery_items[{{ orderItem.id }}]" 
                                                class="form-control form-control-sm delivery-qty text-center" 
                                                placeholder="0.00" 
                                                step="0.01" 
                                                min="0" 
                                                max="{{ remainingQty }}"
                                                value="{{ currentQty }}">
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save"></i> Enregistrer
                            </button>
                            <a href="{{ path('app_bon_livraison_show', {'id': bon_livraison.id}) }}" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
