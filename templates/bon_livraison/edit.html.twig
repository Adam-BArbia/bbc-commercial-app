{% extends 'base.html.twig' %}

{% block title %}{{ 'delivery.edit_title'|trans }} {{ bon_livraison.reference }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h1 class="h3 mb-4">
                <i class="fas fa-edit"></i> {{ 'delivery.edit_title'|trans }} {{ bon_livraison.reference }}
            </h1>

            <div class="card">
                <div class="card-body">
                    <form method="post" id="edit-form">
                        <!-- Order Info (Read-only) -->
                        <div class="alert alert-info">
                            <strong>{{ 'delivery.order_info'|trans }}:</strong> {{ bon_commande.reference }} - 
                            <strong>{{ 'invoice.label_client'|trans }}:</strong> {{ bon_commande.clientSnapshot.name|default(bon_commande.client ? bon_commande.client.name : '-') }}
                        </div>

                        <!-- Delivery Items Table -->
                        <h5 class="mb-3">{{ 'delivery.items_to_deliver'|trans }}</h5>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>{{ 'delivery.col_article'|trans }}</th>
                                        <th class="text-center">{{ 'delivery.col_ordered'|trans }}</th>
                                        <th class="text-center">{{ 'delivery.col_already_delivered'|trans }}</th>
                                        <th class="text-center">{{ 'delivery.col_remaining'|trans }}</th>
                                        <th class="text-center">{{ 'delivery.col_to_deliver'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for orderItem in bon_commande.bonCommandeItems %}
                                    {# Calculate delivered quantity EXCLUDING current BL being edited #}
                                    {% set currentItemDelivery = bon_livraison.bonLivraisonItems.filter(item => item.bonCommandeItem.id == orderItem.id).first() %}
                                    {% set currentQty = currentItemDelivery ? currentItemDelivery.quantityDelivered : 0 %}
                                    {% set deliveredExcludingThis = orderItem.getDeliveredQuantityExcluding(bon_livraison) %}
                                    {% set remainingQty = orderItem.getRemainingQuantityExcluding(bon_livraison) %}
                                    <tr>
                                        <td>{{ orderItem.article.designation }}</td>
                                        <td class="text-center">{{ orderItem.quantity }}</td>
                                        <td class="text-center">{{ deliveredExcludingThis|number_format(2, '.', '') }}</td>
                                        <td class="text-center">{{ remainingQty|number_format(2, '.', '') }}</td>
                                        <td class="text-center">
                                            <input type="number" name="delivery_items[{{ orderItem.id }}]" 
                                                class="form-control form-control-sm delivery-qty text-center" 
                                                placeholder="0.00" 
                                                step="0.01" 
                                                min="0" 
                                                max="{{ remainingQty }}"
                                                value="{{ currentQty }}">
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save"></i> {{ 'delivery.save_btn'|trans }}
                            </button>
                            <a href="{{ path('app_bon_livraison_show', {'id': bon_livraison.id}) }}" class="btn btn-secondary">
                                <i class="fas fa-times"></i> {{ 'common.cancel'|trans }}
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
