{% extends 'base.html.twig' %}

{% block title %}{{ 'profile.change_password'|trans }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="h3 mb-3"><i class="bi bi-key"></i> {{ 'profile.change_password'|trans }}</h1>
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_widget(form) }}
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary">{{ 'profile.update'|trans }}</button>
                    <a href="{{ path('app_dashboard') }}" class="btn btn-outline-secondary">{{ 'common.cancel'|trans }}</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
