{% extends 'base.html.twig' %}

{% block title %}Journal d'audit{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-journal-text"></i> Journal d'audit</h1>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label for="table" class="form-label">Table</label>
                    <input type="text" id="table" name="table" class="form-control" value="{{ filters.table }}" placeholder="facture, payment, ...">
                </div>
                <div class="col-md-2">
                    <label for="action" class="form-label">Action</label>
                    <select id="action" name="action" class="form-select">
                        <option value="" {% if filters.action == '' %}selected{% endif %}>Toutes</option>
                        <option value="CREATE" {% if filters.action == 'CREATE' %}selected{% endif %}>CREATE</option>
                        <option value="UPDATE" {% if filters.action == 'UPDATE' %}selected{% endif %}>UPDATE</option>
                        <option value="DELETE" {% if filters.action == 'DELETE' %}selected{% endif %}>DELETE</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="user" class="form-label">Utilisateur</label>
                    <select id="user" name="user" class="form-select">
                        <option value="0" {% if filters.user == 0 %}selected{% endif %}>Tous</option>
                        {% for user in users %}
                            <option value="{{ user.id }}" {% if filters.user == user.id %}selected{% endif %}>{{ user.name }} ({{ user.email }})</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="date_from" class="form-label">Date debut</label>
                    <input type="date" id="date_from" name="date_from" class="form-control" value="{{ filters.date_from }}">
                </div>
                <div class="col-md-2">
                    <label for="date_to" class="form-label">Date fin</label>
                    <input type="date" id="date_to" name="date_to" class="form-control" value="{{ filters.date_to }}">
                </div>
                <div class="col-12 d-flex gap-2">
                    <button class="btn btn-secondary" type="submit"><i class="bi bi-search"></i> Filtrer</button>
                    <a href="{{ path('app_audit_log_index') }}" class="btn btn-outline-secondary">Reinitialiser</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">Entrees ({{ pagination.total_items }})</h5>
        </div>
        <div class="card-body p-0">
            {% if logs|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Utilisateur</th>
                                <th>Table</th>
                                <th>ID</th>
                                <th>Action</th>
                                <th>Anciennes donnees</th>
                                <th>Nouvelles donnees</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for log in logs %}
                                <tr>
                                    <td>{{ log.performedAt|date('d/m/Y H:i:s') }}</td>
                                    <td>{{ log.performedBy ? log.performedBy.name : '-' }}</td>
                                    <td><code>{{ log.tableName }}</code></td>
                                    <td>{{ log.recordId }}</td>
                                    <td>
                                        {% if log.action == 'CREATE' %}
                                            <span class="badge bg-success">CREATE</span>
                                        {% elseif log.action == 'UPDATE' %}
                                            <span class="badge bg-warning text-dark">UPDATE</span>
                                        {% elseif log.action == 'DELETE' %}
                                            <span class="badge bg-danger">DELETE</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ log.action }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if log.oldData %}
                                            <pre class="mb-0 small">{{ log.oldData|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if log.newData %}
                                            <pre class="mb-0 small">{{ log.newData|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {% if pagination.total_pages > 1 %}
                    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
                        <small class="text-muted">Page {{ pagination.page }} / {{ pagination.total_pages }}</small>
                        <div class="btn-group btn-group-sm">
                            {% if pagination.page > 1 %}
                                <a class="btn btn-outline-secondary" href="{{ path('app_audit_log_index', app.request.query.all|merge({'page': pagination.page - 1})) }}">Precedent</a>
                            {% else %}
                                <button class="btn btn-outline-secondary" disabled>Precedent</button>
                            {% endif %}

                            {% if pagination.page < pagination.total_pages %}
                                <a class="btn btn-outline-secondary" href="{{ path('app_audit_log_index', app.request.query.all|merge({'page': pagination.page + 1})) }}">Suivant</a>
                            {% else %}
                                <button class="btn btn-outline-secondary" disabled>Suivant</button>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            {% else %}
                <div class="text-center py-5 text-muted">Aucune entree d'audit</div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
