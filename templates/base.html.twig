<!DOCTYPE html>
<html lang="fr" data-bs-theme="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}BBC Commercial{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📦</text></svg>">
        
        {# Bootstrap 5 CSS #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        
        <style>
            /* ── CSS custom properties ──────────────────────────────────── */
            :root {
                /* Keep Bootstrap primary blue, tweak slightly for richer tone */
                --bbc-blue:        #1a6fc4;   /* slightly deeper blue for links/accents  */
                --bbc-blue-light:  #e8f0fb;   /* tinted bg for highlighted cells          */

                /* Light mode tokens */
                --bbc-body-bg:     #eef1f6;   /* cool off-white — more contrast  vs cards */
                --bbc-surface:     #ffffff;   /* card / panel surface                     */
                --bbc-surface-alt: #e4e9f0;   /* card headers, table headers              */
                --bbc-border:      #c4ccd8;   /* visible but subtle borders               */
                --bbc-text:        #1a1d23;   /* near-black body text                     */
                --bbc-text-muted:  #49576a;   /* muted text — WCAG AA on white            */
                --bbc-footer-bg:   #dde3ec;
            }

            [data-bs-theme="dark"] {
                --bbc-body-bg:     #12161b;   /* deep navy-black                          */
                --bbc-surface:     #1c2330;   /* card surface                             */
                --bbc-surface-alt: #232d3d;   /* card headers, table headers              */
                --bbc-border:      #2e3d52;   /* visible borders                          */
                --bbc-text:        #e6edf6;   /* near-white body text                     */
                --bbc-text-muted:  #8faabf;   /* muted — readable on dark bg              */
                --bbc-footer-bg:   #161d27;
            }

            /* ── Base ───────────────────────────────────────────────────── */
            html, body {
                min-height: 100vh;
            }
            body {
                background-color: var(--bbc-body-bg);
                color: var(--bbc-text);
            }

            /* ── Navbar ─────────────────────────────────────────────────── */
            .navbar.bg-primary {
                background-color: #1558a8 !important;   /* rich dark-blue, better contrast  */
            }
            [data-bs-theme="dark"] .navbar.bg-primary {
                background-color: #0e3d78 !important;
            }

            /* ── Cards ──────────────────────────────────────────────────── */
            .card {
                background-color: var(--bbc-surface);
                border-color: var(--bbc-border);
            }
            .card-header.bg-light,
            .card-header {
                background-color: var(--bbc-surface-alt) !important;
                color: var(--bbc-text) !important;
                border-bottom-color: var(--bbc-border) !important;
            }

            /* ── Tables ─────────────────────────────────────────────────── */
            .table {
                --bs-table-color:      var(--bbc-text);
                --bs-table-bg:         var(--bbc-surface);
                --bs-table-striped-bg: color-mix(in srgb, var(--bbc-surface-alt) 60%, var(--bbc-surface));
                --bs-table-hover-bg:   var(--bbc-blue-light);
                --bs-table-border-color: var(--bbc-border);
            }
            .table thead.table-light th,
            .table thead th {
                background-color: var(--bbc-surface-alt) !important;
                color: var(--bbc-text) !important;
                border-color: var(--bbc-border) !important;
            }

            /* ── Forms ──────────────────────────────────────────────────── */
            .form-control,
            .form-select {
                background-color: var(--bbc-surface);
                border-color: var(--bbc-border);
                color: var(--bbc-text);
            }
            .form-control:focus,
            .form-select:focus {
                background-color: var(--bbc-surface);
                border-color: var(--bbc-blue);
                color: var(--bbc-text);
                box-shadow: 0 0 0 0.2rem rgba(26, 111, 196, 0.25);
            }
            .form-label {
                color: var(--bbc-text);
                font-weight: 500;
            }

            /* ── Text utilities ─────────────────────────────────────────── */
            .text-muted {
                color: var(--bbc-text-muted) !important;
            }

            /* ── Dropdown menus ─────────────────────────────────────────── */
            .dropdown-menu {
                background-color: var(--bbc-surface);
                border-color: var(--bbc-border);
            }
            .dropdown-item {
                color: var(--bbc-text);
            }
            .dropdown-item:hover, .dropdown-item:focus {
                background-color: var(--bbc-surface-alt);
                color: var(--bbc-text);
            }
            .dropdown-divider {
                border-color: var(--bbc-border);
            }

            /* ── Alerts ─────────────────────────────────────────────────── */
            [data-bs-theme="dark"] .alert-primary {
                background-color: #1a3a5c;
                border-color: #1558a8;
                color: #cfe0ff;
            }
            [data-bs-theme="dark"] .alert-success {
                background-color: #1a3d2b;
                border-color: #28a745;
                color: #c5e8d0;
            }
            [data-bs-theme="dark"] .alert-info {
                background-color: #133040;
                border-color: #0dcaf0;
                color: #b8e8f5;
            }
            [data-bs-theme="dark"] .alert-warning {
                background-color: #3d2e10;
                border-color: #ffc107;
                color: #ffe8a1;
            }
            [data-bs-theme="dark"] .alert-danger {
                background-color: #3d1a1a;
                border-color: #dc3545;
                color: #f5c2c7;
            }
            [data-bs-theme="dark"] .alert-secondary {
                background-color: #2c333d;
                border-color: #6c757d;
                color: #c8d3de;
            }

            /* ── Borders & misc ─────────────────────────────────────────── */
            .border-top,
            .border-bottom,
            .border {
                border-color: var(--bbc-border) !important;
            }

            /* ── Footer ─────────────────────────────────────────────────── */
            footer.bg-light {
                background-color: var(--bbc-footer-bg) !important;
                border-color: var(--bbc-border) !important;
                color: var(--bbc-text-muted) !important;
            }

            /* ── Badges: white text on Bootstrap's original yellow ─────── */
            .badge.bg-warning {
                color: #fff !important;
            }

            /* ── KPI cards on dashboard – keep rich colors but fix text ── */
            .card.bg-primary .text-white-50,
            .card.bg-success .text-white-50,
            .card.bg-info    .text-white-50 {
                opacity: 0.85;   /* was 0.5 – too low contrast */
            }

            /* ── Pagination ─────────────────────────────────────────────── */
            .page-link {
                background-color: var(--bbc-surface);
                border-color: var(--bbc-border);
                color: var(--bbc-blue);
            }
            .page-link:hover {
                background-color: var(--bbc-surface-alt);
            }
            .page-item.active .page-link {
                background-color: #1558a8;
                border-color: #1558a8;
            }
            .page-item.disabled .page-link {
                background-color: var(--bbc-surface);
                color: var(--bbc-text-muted);
            }

            /* ── Theme toggle button ────────────────────────────────────── */
            .theme-toggle {
                cursor: pointer;
                transition: transform 0.3s ease;
            }
            .theme-toggle:hover {
                transform: rotate(20deg);
            }
        </style>
        
        {% block stylesheets %}
        {% endblock %}
    </head>
    <body>
        {% if app.user %}
        {# Navigation Bar #}
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container-fluid">
                <a class="navbar-brand" href="{{ path('app_dashboard') }}">
                    <i class="bi bi-box-seam"></i> BBC Commercial
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_dashboard') }}">
                                <i class="bi bi-house"></i> {{ 'nav.dashboard'|trans }}
                            </a>
                        </li>
                        {% if has_privilege('CLIENT_VIEW') or has_privilege('ARTICLE_VIEW') %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-folder"></i> {{ 'nav.management'|trans }}
                            </a>
                            <ul class="dropdown-menu">
                                {% if has_privilege('CLIENT_VIEW') %}
                                <li><a class="dropdown-item" href="{{ path('app_client_index') }}"><i class="bi bi-people"></i> {{ 'nav.clients'|trans }}</a></li>
                                {% endif %}
                                {% if has_privilege('ARTICLE_VIEW') %}
                                <li><a class="dropdown-item" href="{{ path('app_article_index') }}"><i class="bi bi-box-seam"></i> {{ 'nav.articles'|trans }}</a></li>
                                {% endif %}
                            </ul>
                        </li>
                        {% endif %}
                        {% if has_privilege('ORDER_VIEW') or has_privilege('DELIVERY_VIEW') or has_privilege('INVOICE_VIEW') or has_privilege('PAYMENT_VIEW') %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-cart"></i> {{ 'nav.commercial'|trans }}
                            </a>
                            <ul class="dropdown-menu">
                                {% if has_privilege('ORDER_VIEW') %}
                                <li><a class="dropdown-item" href="{{ path('app_bon_commande_index') }}">{{ 'nav.orders'|trans }}</a></li>
                                {% endif %}
                                {% if has_privilege('DELIVERY_VIEW') %}
                                <li><a class="dropdown-item" href="{{ path('app_bon_livraison_index') }}">{{ 'nav.deliveries'|trans }}</a></li>
                                {% endif %}
                                {% if has_privilege('INVOICE_VIEW') %}
                                <li><a class="dropdown-item" href="{{ path('app_facture_index') }}">{{ 'nav.invoices'|trans }}</a></li>
                                {% endif %}
                                {% if has_privilege('PAYMENT_VIEW') %}
                                <li><a class="dropdown-item" href="{{ path('app_payment_index') }}">{{ 'nav.payments'|trans }}</a></li>
                                {% endif %}
                                <li><a class="dropdown-item" href="{{ path('app_reports_index') }}"><i class="bi bi-graph-up-arrow"></i> {{ 'nav.reports'|trans }}</a></li>
                                {% if has_privilege('AUDIT_VIEW') %}
                                <li><a class="dropdown-item" href="{{ path('app_audit_log_index') }}">{{ 'nav.audit'|trans }}</a></li>
                                {% endif %}
                            </ul>
                        </li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-gear"></i> {{ 'nav.admin'|trans }}
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('admin_user_index') }}">{{ 'nav.users'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('admin_role_index') }}">{{ 'nav.roles'|trans }}</a></li>
                                <li><hr class="dropdown-divider"></li>
                                {% if has_privilege('AUDIT_VIEW') %}
                                <li><a class="dropdown-item" href="{{ path('app_audit_log_index') }}">{{ 'nav.audit'|trans }}</a></li>
                                {% endif %}
                            </ul>
                        </li>
                        {% endif %}
                    </ul>
                    <ul class="navbar-nav">
                        {# Language switcher #}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-2" href="#" role="button" data-bs-toggle="dropdown" title="{{ 'nav.language'|trans }}">
                                {% if app.request.locale == 'en' %}
                                    🇬🇧 EN
                                {% else %}
                                    🇫🇷 FR
                                {% endif %}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item {% if app.request.locale == 'fr' %}active{% endif %}"
                                       href="{{ path('app_switch_locale', {locale: 'fr'}) }}">
                                        🇫🇷 Français
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item {% if app.request.locale == 'en' %}active{% endif %}"
                                       href="{{ path('app_switch_locale', {locale: 'en'}) }}">
                                        🇬🇧 English
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link btn btn-link theme-toggle" id="themeToggle" title="Changer le thème">
                                <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                            </button>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> {{ app.user.name }}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="#">{{ 'nav.profile'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_profile_change_password') }}">{{ 'nav.change_password'|trans }}</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right"></i> {{ 'nav.logout'|trans }}
                                </a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        {% endif %}

        {# Flash Messages #}
        <div class="container mt-3">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        {# Main Content #}
        {% block body %}{% endblock %}

        {# Footer #}
        {% if app.user %}
        <footer class="footer mt-auto py-3 bg-light border-top">
            <div class="container text-center text-muted">
                <small>BBC Commercial App © {{ 'now'|date('Y') }} - v1.0</small>
            </div>
        </footer>
        <script>
            // Dark mode toggle functionality
            const htmlElement = document.documentElement;
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = document.getElementById('themeIcon');
            
            // Check for saved theme preference or default to 'light'
            const currentTheme = localStorage.getItem('theme') || 'light';
            htmlElement.setAttribute('data-bs-theme', currentTheme);
            updateThemeIcon(currentTheme);
            
            // Theme toggle button click handler
            if (themeToggle) {
                themeToggle.addEventListener('click', function() {
                    const currentTheme = htmlElement.getAttribute('data-bs-theme');
                    const newTheme = currentTheme === 'light' ? 'dark' : 'light';
                    
                    htmlElement.setAttribute('data-bs-theme', newTheme);
                    localStorage.setItem('theme', newTheme);
                    updateThemeIcon(newTheme);
                });
            }
            
            function updateThemeIcon(theme) {
                if (themeIcon) {
                    if (theme === 'dark') {
                        themeIcon.className = 'bi bi-sun-fill';
                    } else {
                        themeIcon.className = 'bi bi-moon-stars-fill';
                    }
                }
            }
        </script>
        
        {% endif %}

        {# Bootstrap 5 JS Bundle #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        
        {% block javascripts %}
        {% endblock %}
    </body>
</html>
