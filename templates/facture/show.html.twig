{% extends 'base.html.twig' %}

{% block title %}Facture {{ facture.reference }}{% endblock %}

{% block body %}
<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1"><i class="bi bi-receipt"></i> {{ facture.reference }}</h1>
            <div class="text-muted">Creee le {{ facture.createdAt|date('d/m/Y H:i') }}</div>
        </div>
        <div class="text-end">
            {% if facture.status == 'CANCELLED' %}
                <span class="badge bg-danger fs-6">Annulee</span>
            {% elseif facture.status == 'PAID' %}
                <span class="badge bg-success fs-6">Payee</span>
            {% elseif facture.status == 'PARTIALLY_PAID' %}
                <span class="badge bg-warning text-dark fs-6">Partiellement payee</span>
            {% elseif facture.status == 'UNPAID' %}
                <span class="badge bg-primary fs-6">Impayee</span>
            {% else %}
                <span class="badge bg-secondary fs-6">{{ facture.status }}</span>
            {% endif %}
            {% if facture.cancelledAt %}
                <div class="small text-muted mt-1">Annulee le {{ facture.cancelledAt|date('d/m/Y H:i') }}</div>
            {% endif %}
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Informations</h5>
                </div>
                <div class="card-body">
                    {% set clientSnapshot = facture.clientSnapshot %}
                    {% set firstDelivery = facture.bonLivraisons|first %}
                    {% set order = firstDelivery and firstDelivery.bonCommande ? firstDelivery.bonCommande : null %}
                    {% set client = order ? order.client : null %}
                    {% set clientName = clientSnapshot and clientSnapshot.name is defined ? clientSnapshot.name : (order ? order.clientSnapshot.name|default(client ? client.name : '-') : '-') %}
                    {% set clientCode = clientSnapshot and clientSnapshot.client_code is defined ? clientSnapshot.client_code : (order ? order.clientSnapshot.client_code|default(client ? client.clientCode : '-') : '-') %}
                    {% set deliveryCount = facture.deliverySnapshot ? facture.deliverySnapshot|length : facture.bonLivraisons|length %}

                    <div class="mb-3">
                        <label class="text-muted">Client</label>
                        <p class="mb-0"><strong>{{ clientName }}</strong></p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted">Code client</label>
                        <p class="mb-0"><strong>{{ clientCode }}</strong></p>
                    </div>
                    <div>
                        <label class="text-muted">Bons de livraison lies</label>
                        <p class="mb-0"><strong>{{ deliveryCount }}</strong></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-calculator"></i> Totaux</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Total HT</span>
                        <strong>{{ facture.totalHt|number_format(3, '.', ' ') }} TND</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>TVA ({{ facture.tvaRate|number_format(2, '.', ' ') }}%)</span>
                        <strong>{{ facture.tvaAmount|number_format(3, '.', ' ') }} TND</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Timbre</span>
                        <strong>{{ facture.timbre|number_format(3, '.', ' ') }} TND</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">Total TTC</span>
                        <strong class="text-primary">{{ facture.totalTtc|number_format(3, '.', ' ') }} TND</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-list-check"></i> Lignes de facture</h5>
            <span class="badge text-bg-secondary">{{ facture.factureItems|length }} ligne(s)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Article</th>
                            <th class="text-end">Quantite</th>
                            <th class="text-end">Prix unitaire</th>
                            <th class="text-end">Total ligne HT</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in facture.factureItems %}
                            <tr>
                                <td>
                                    <strong>{{ item.article.code }}</strong>
                                    <div class="text-muted">{{ item.article.designation }}</div>
                                </td>
                                <td class="text-end">{{ item.quantity|number_format(2, '.', ' ') }}</td>
                                <td class="text-end">{{ item.unitPrice|number_format(3, '.', ' ') }} TND</td>
                                <td class="text-end fw-semibold">{{ item.totalLineHt|number_format(3, '.', ' ') }} TND</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">Aucune ligne</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-truck"></i> Bons de livraison lies</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Reference BL</th>
                            <th>Date creation</th>
                            <th>Commande</th>
                            <th class="text-center">Statut BL</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if facture.bonLivraisons|length > 0 %}
                            {% for delivery in facture.bonLivraisons %}
                                <tr>
                                    <td><strong>{{ delivery.reference }}</strong></td>
                                    <td>{{ delivery.createdAt|date('d/m/Y H:i') }}</td>
                                    <td>{{ delivery.bonCommande.reference }}</td>
                                    <td class="text-center">
                                        {% if delivery.status == 'CANCELLED' %}
                                            <span class="badge bg-danger">Annule</span>
                                        {% elseif delivery.status == 'VALIDATED' %}
                                            <span class="badge bg-success">Valide</span>
                                        {% else %}
                                            <span class="badge bg-warning text-dark">Brouillon</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="{{ path('app_bon_livraison_show', {'id': delivery.id}) }}" class="btn btn-outline-secondary" title="Voir BL">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% elseif facture.deliverySnapshot and facture.deliverySnapshot|length > 0 %}
                            {% for delivery in facture.deliverySnapshot %}
                                <tr>
                                    <td><strong>{{ delivery.reference|default('-') }}</strong></td>
                                    <td>
                                        {% if delivery.created_at is defined and delivery.created_at %}
                                            {{ delivery.created_at|date('d/m/Y H:i') }}
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                    <td>{{ delivery.order_reference|default('-') }}</td>
                                    <td class="text-center">
                                        {% if delivery.status|default('') == 'CANCELLED' %}
                                            <span class="badge bg-danger">Annule</span>
                                        {% elseif delivery.status|default('') == 'VALIDATED' %}
                                            <span class="badge bg-success">Valide</span>
                                        {% else %}
                                            <span class="badge bg-warning text-dark">{{ delivery.status|default('N/A') }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if delivery.id is defined and delivery.id %}
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="{{ path('app_bon_livraison_show', {'id': delivery.id}) }}" class="btn btn-outline-secondary" title="Voir BL">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </div>
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">Aucun bon de livraison lie</td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a href="{{ path('app_facture_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour a la liste
        </a>

        {% if has_privilege('INVOICE_CANCEL') and facture.status != 'CANCELLED' %}
            <form method="post" action="{{ path('app_facture_cancel', {'id': facture.id}) }}" onsubmit="return confirm('Confirmer l\'annulation logique de cette facture ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ facture.id) }}">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-x-circle"></i> Annuler la facture
                </button>
            </form>
        {% endif %}
    </div>
</div>
{% endblock %}
