{% extends 'base.html.twig' %}

{% block title %}{{ 'invoice.title'|trans }} {{ facture.reference }}{% endblock %}

{% block body %}
<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1"><i class="bi bi-receipt"></i> {{ facture.reference }}</h1>
            <div class="text-muted">{{ 'invoice.created_at'|trans }} {{ facture.createdAt|date('d/m/Y H:i') }}</div>
        </div>
        <div class="text-end">
            {% if facture.status == 'CANCELLED' %}
                <span class="badge bg-danger fs-6">{{ 'status.cancelled'|trans }}</span>
            {% elseif facture.status == 'PAID' %}
                <span class="badge bg-success fs-6">{{ 'status.paid'|trans }}</span>
            {% elseif facture.status == 'PARTIALLY_PAID' %}
                <span class="badge bg-warning text-dark fs-6">{{ 'status.partially_paid'|trans }}</span>
            {% elseif facture.status == 'UNPAID' %}
                <span class="badge bg-primary fs-6">{{ 'status.unpaid'|trans }}</span>
            {% else %}
                <span class="badge bg-secondary fs-6">{{ facture.status }}</span>
            {% endif %}
            {% if facture.cancelledAt %}
                <div class="small text-muted mt-1">{{ 'invoice.cancelled_at'|trans }} {{ facture.cancelledAt|date('d/m/Y H:i') }}</div>
            {% endif %}
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> {{ 'invoice.info_section'|trans }}</h5>
                </div>
                <div class="card-body">
                    {% set clientSnapshot = facture.clientSnapshot %}
                    {% set firstDelivery = facture.bonLivraisons|first %}
                    {% set order = firstDelivery and firstDelivery.bonCommande ? firstDelivery.bonCommande : null %}
                    {% set client = order ? order.client : null %}
                    {% set clientName = clientSnapshot and clientSnapshot.name is defined ? clientSnapshot.name : (order ? order.clientSnapshot.name|default(client ? client.name : '-') : '-') %}
                    {% set clientCode = clientSnapshot and clientSnapshot.client_code is defined ? clientSnapshot.client_code : (order ? order.clientSnapshot.client_code|default(client ? client.clientCode : '-') : '-') %}
                    {% set deliveryCount = facture.deliverySnapshot ? facture.deliverySnapshot|length : facture.bonLivraisons|length %}

                    <div class="mb-3">
                        <label class="text-muted">{{ 'invoice.label_client'|trans }}</label>
                        <p class="mb-0"><strong>{{ clientName }}</strong></p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted">{{ 'invoice.label_client_code'|trans }}</label>
                        <p class="mb-0"><strong>{{ clientCode }}</strong></p>
                    </div>
                    <div>
                        <label class="text-muted">{{ 'invoice.label_linked_bl'|trans }}</label>
                        <p class="mb-0"><strong>{{ deliveryCount }}</strong></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-calculator"></i> {{ 'invoice.totals_section'|trans }}</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>{{ 'invoice.subtotal_ht'|trans }}</span>
                        <strong>{{ facture.subtotalHt|number_format(3, '.', ' ') }} TND</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>{{ 'invoice.remise'|trans }}</span>
                        <strong>- {{ facture.remise|number_format(3, '.', ' ') }} TND</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>{{ 'invoice.total_ht'|trans }}</span>
                        <strong>{{ facture.totalHt|number_format(3, '.', ' ') }} TND</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>{{ 'invoice.tva'|trans }} ({{ facture.tvaRate|number_format(2, '.', ' ') }}%)</span>
                        <strong>{{ facture.tvaAmount|number_format(3, '.', ' ') }} TND</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>{{ 'invoice.timbre'|trans }}</span>
                        <strong>{{ facture.timbre|number_format(3, '.', ' ') }} TND</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">{{ 'invoice.total_ttc'|trans }}</span>
                        <strong class="text-primary">{{ facture.totalTtc|number_format(3, '.', ' ') }} TND</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-list-check"></i> {{ 'invoice.items_section'|trans }}</h5>
            <span class="badge text-bg-secondary">{{ 'common.line_count'|trans({'%count%': facture.factureItems|length}) }}</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>{{ 'invoice.col_article'|trans }}</th>
                            <th class="text-end">{{ 'invoice.col_qty'|trans }}</th>
                            <th class="text-end">{{ 'invoice.col_unit_price'|trans }}</th>
                            <th class="text-end">{{ 'invoice.col_total_line'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in facture.factureItems %}
                            <tr>
                                <td>
                                    <strong>{{ item.article.code }}</strong>
                                    <div class="text-muted">{{ item.article.designation }}</div>
                                </td>
                                <td class="text-end">{{ item.quantity|number_format(2, '.', ' ') }}</td>
                                <td class="text-end">{{ item.unitPrice|number_format(3, '.', ' ') }} TND</td>
                                <td class="text-end fw-semibold">{{ item.totalLineHt|number_format(3, '.', ' ') }} TND</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">{{ 'invoice.no_lines'|trans }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-truck"></i> {{ 'invoice.bl_section'|trans }}</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>{{ 'invoice.col_bl_ref'|trans }}</th>
                            <th>{{ 'invoice.col_bl_date'|trans }}</th>
                            <th>{{ 'invoice.col_bl_order'|trans }}</th>
                            <th class="text-center">{{ 'invoice.col_bl_status'|trans }}</th>
                            <th class="text-center">{{ 'invoice.col_bl_actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if facture.bonLivraisons|length > 0 %}
                            {% for delivery in facture.bonLivraisons %}
                                <tr>
                                    <td><strong>{{ delivery.reference }}</strong></td>
                                    <td>{{ delivery.createdAt|date('d/m/Y H:i') }}</td>
                                    <td>{{ delivery.bonCommande.reference }}</td>
                                    <td class="text-center">
                                        {% if delivery.status == 'CANCELLED' %}
                                                <span class="badge bg-danger">{{ 'status.cancelled'|trans }}</span>
                                        {% elseif delivery.status == 'VALIDATED' %}
                                                <span class="badge bg-success">{{ 'status.validated'|trans }}</span>
                                        {% else %}
                                                <span class="badge bg-warning text-dark">{{ 'status.draft'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                                <a href="{{ path('app_bon_livraison_show', {'id': delivery.id}) }}" class="btn btn-outline-secondary" title="{{ 'common.see_all'|trans }}">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% elseif facture.deliverySnapshot and facture.deliverySnapshot|length > 0 %}
                            {% for delivery in facture.deliverySnapshot %}
                                <tr>
                                    <td><strong>{{ delivery.reference|default('-') }}</strong></td>
                                    <td>
                                        {% if delivery.created_at is defined and delivery.created_at %}
                                            {{ delivery.created_at|date('d/m/Y H:i') }}
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                    <td>{{ delivery.order_reference|default('-') }}</td>
                                    <td class="text-center">
                                        {% if delivery.status|default('') == 'CANCELLED' %}
                                            <span class="badge bg-danger">{{ 'status.cancelled'|trans }}</span>
                                        {% elseif delivery.status|default('') == 'VALIDATED' %}
                                            <span class="badge bg-success">{{ 'status.validated'|trans }}</span>
                                        {% else %}
                                            <span class="badge bg-warning text-dark">{{ delivery.status|default('N/A') }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if delivery.id is defined and delivery.id %}
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="{{ path('app_bon_livraison_show', {'id': delivery.id}) }}" class="btn btn-outline-secondary" title="{{ 'common.see_all'|trans }}">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </div>
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">{{ 'invoice.no_linked_bl'|trans }}</td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a href="{{ path('app_facture_index') }}" class="btn btn-outline-secondary">
              <i class="bi bi-arrow-left"></i> {{ 'common.back_to_list'|trans }}
        </a>

        {% if has_privilege('INVOICE_CANCEL') and facture.status != 'CANCELLED' %}
                <form method="post" action="{{ path('app_facture_cancel', {'id': facture.id}) }}" onsubmit="return confirm('{{ 'invoice.confirm_cancel'|trans }}')">
                <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ facture.id) }}">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-x-circle"></i> {{ 'invoice.cancel_btn'|trans }}
                </button>
            </form>
        {% endif %}
    </div>
</div>
{% endblock %}
