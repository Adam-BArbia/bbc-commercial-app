{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.reset_password'|trans }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="h3 mb-3"><i class="bi bi-key"></i> {{ 'admin.reset_password'|trans }}</h1>
    <div class="card">
        <div class="card-body">
            <p class="text-muted">{{ 'admin.reset_pw_user_label'|trans }} : <strong>{{ userEntity.name }}</strong> ({{ userEntity.email }})</p>
            {{ form_start(form) }}
                {{ form_widget(form) }}
                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-warning" type="submit">{{ 'admin.reset_password_btn'|trans }}</button>
                    <a href="{{ path('admin_user_index') }}" class="btn btn-outline-secondary">{{ 'admin.back'|trans }}</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
