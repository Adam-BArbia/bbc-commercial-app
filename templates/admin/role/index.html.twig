{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.roles_title'|trans }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0"><i class="bi bi-shield-lock"></i> {{ 'admin.roles_title'|trans }}</h1>
        <a href="{{ path('admin_role_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> {{ 'admin.roles_new'|trans }}
        </a>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'admin.role_col_name'|trans }}</th>
                        <th>{{ 'admin.role_col_privileges'|trans }}</th>
                        <th>{{ 'admin.role_col_users'|trans }}</th>
                        <th class="text-end">{{ 'admin.role_col_actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for role in roles %}
                        <tr>
                            <td><span class="badge bg-dark">{{ role.name }}</span></td>
                            <td>{{ role.privileges|length }}</td>
                            <td>{{ role.users|length }}</td>
                            <td class="text-end">
                                <a href="{{ path('admin_role_edit', {id: role.id}) }}" class="btn btn-sm btn-outline-primary">{{ 'admin.edit_btn'|trans }}</a>
                                <form method="post" action="{{ path('admin_role_delete', {id: role.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'admin.confirm_delete_role'|trans }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete-role-' ~ role.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'admin.delete_btn'|trans }}</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">{{ 'admin.no_roles'|trans }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
