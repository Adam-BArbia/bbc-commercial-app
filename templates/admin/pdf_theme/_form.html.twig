    <script>
        const paper = document.getElementById('paper');
        const dragHint = document.getElementById('drag-hint');
        const bgImage = document.getElementById('paper-bg');
        const fileInput = document.getElementById('{{ form.imageFile.vars.id }}');
        const snapEnabledInput = document.getElementById('snap-enabled');
        const snapStepInput = document.getElementById('snap-step');

        function getPaperMetrics() {
            return {
                widthPx: paper.clientWidth,
                heightPx: paper.clientHeight,
                widthMm: parseFloat(paper.dataset.widthMm || '210'),
                heightMm: parseFloat(paper.dataset.heightMm || '297')
            };
        }

        function mmToPxX(mm, metrics) {
            return (mm / metrics.widthMm) * metrics.widthPx;
        }

        function mmToPxY(mm, metrics) {
            return (mm / metrics.heightMm) * metrics.heightPx;
        }

        function pxToMmX(px, metrics) {
            return (px / metrics.widthPx) * metrics.widthMm;
        }

        function pxToMmY(px, metrics) {
            return (px / metrics.heightPx) * metrics.heightMm;
        }

        function getSnapStep() {
            if (!snapEnabledInput || !snapEnabledInput.checked) {
                return 0;
            }

            return parseFloat(snapStepInput.value || '1');
        }

        function snapValue(value) {
            const step = getSnapStep();
            if (!step || step <= 0) {
                return value;
            }

            return Math.round(value / step) * step;
        }

        function getOtherZonesMm(activeZone) {
            return Array.from(document.querySelectorAll('.drag-zone'))
                .filter((z) => z !== activeZone)
                .map((z) => {
                    const x = readField(z.dataset.x);
                    const y = readField(z.dataset.y);
                    const w = readField(z.dataset.w);
                    const h = readField(z.dataset.h);
                    return {
                        left: x,
                        right: x + w,
                        top: y,
                        bottom: y + h
                    };
                });
        }

        function snapMoveToZones(xMm, yMm, wMm, hMm, activeZone) {
            if (!snapEnabledInput || !snapEnabledInput.checked) {
                return { xMm, yMm };
            }

            const threshold = Math.max(0.8, getSnapStep() || 1);
            const others = getOtherZonesMm(activeZone);

            const left = xMm;
            const right = xMm + wMm;
            const top = yMm;
            const bottom = yMm + hMm;

            let bestDx = null;
            let bestDy = null;

            function updateBest(current, candidate) {
                if (Math.abs(candidate) > threshold) {
                    return current;
                }
                if (current === null || Math.abs(candidate) < Math.abs(current)) {
                    return candidate;
                }
                return current;
            }

            others.forEach((o) => {
                bestDx = updateBest(bestDx, o.left - left);
                bestDx = updateBest(bestDx, o.right - left);
                bestDx = updateBest(bestDx, o.left - right);
                bestDx = updateBest(bestDx, o.right - right);

                bestDy = updateBest(bestDy, o.top - top);
                bestDy = updateBest(bestDy, o.bottom - top);
                bestDy = updateBest(bestDy, o.top - bottom);
                bestDy = updateBest(bestDy, o.bottom - bottom);
            });

            return {
                xMm: xMm + (bestDx || 0),
                yMm: yMm + (bestDy || 0)
            };
        }

        function snapResizeToZones(xMm, yMm, wMm, hMm, activeZone) {
            if (!snapEnabledInput || !snapEnabledInput.checked) {
                return { wMm, hMm };
            }

            const threshold = Math.max(0.8, getSnapStep() || 1);
            const others = getOtherZonesMm(activeZone);

            const right = xMm + wMm;
            const bottom = yMm + hMm;

            let bestDw = null;
            let bestDh = null;

            function updateBest(current, candidate) {
                if (Math.abs(candidate) > threshold) {
                    return current;
                }
                if (current === null || Math.abs(candidate) < Math.abs(current)) {
                    return candidate;
                }
                return current;
            }

            others.forEach((o) => {
                bestDw = updateBest(bestDw, o.left - right);
                bestDw = updateBest(bestDw, o.right - right);

                bestDh = updateBest(bestDh, o.top - bottom);
                bestDh = updateBest(bestDh, o.bottom - bottom);
            });

            return {
                wMm: Math.max(5, wMm + (bestDw || 0)),
                hMm: Math.max(5, hMm + (bestDh || 0))
            };
        }

        function readField(id) {
            const input = document.getElementById(id);
            if (!input) {
                return 0;
            }

            return parseFloat(input.value || '0');
        }

        function writeField(id, value) {
            const input = document.getElementById(id);
            if (!input) {
                return;
            }

            const min = parseFloat(input.min || '0');
            const max = parseFloat(input.max || '999');
            const normalized = Math.max(min, Math.min(max, value));
            input.value = normalized.toFixed(2);
            input.dispatchEvent(new Event('input', { bubbles: true }));
        }

        function placeZone(zoneElement) {
            const metrics = getPaperMetrics();
            const xMm = readField(zoneElement.dataset.x);
            const yMm = readField(zoneElement.dataset.y);
            const wMm = readField(zoneElement.dataset.w);
            const hMm = readField(zoneElement.dataset.h);

            zoneElement.style.left = mmToPxX(xMm, metrics) + 'px';
            zoneElement.style.top = mmToPxY(yMm, metrics) + 'px';
            zoneElement.style.width = Math.max(20, mmToPxX(wMm, metrics)) + 'px';
            zoneElement.style.height = Math.max(20, mmToPxY(hMm, metrics)) + 'px';
        }

        function refreshAllZones() {
            document.querySelectorAll('.drag-zone').forEach(placeZone);
        }

        let interactionState = null;

        document.querySelectorAll('.drag-zone').forEach((zoneElement) => {
            zoneElement.addEventListener('mousedown', (event) => {
                event.preventDefault();

                const zoneRect = zoneElement.getBoundingClientRect();
                const isResize = event.target.classList.contains('resize-handle');

                interactionState = {
                    zoneElement,
                    mode: isResize ? 'resize' : 'move',
                    offsetX: event.clientX - zoneRect.left,
                    offsetY: event.clientY - zoneRect.top,
                    startWidth: zoneRect.width,
                    startHeight: zoneRect.height,
                    startMouseX: event.clientX,
                    startMouseY: event.clientY,
                    startLeft: zoneRect.left,
                    startTop: zoneRect.top
                };

                zoneElement.classList.add('active');
                dragHint.textContent = (isResize ? 'Redimensionnement: ' : 'Deplacement: ') + zoneElement.querySelector('.zone-label').textContent.trim();
            });
        });

        window.addEventListener('mousemove', (event) => {
            if (!interactionState) {
                return;
            }

            const metrics = getPaperMetrics();
            const paperRect = paper.getBoundingClientRect();
            const zone = interactionState.zoneElement;

            if (interactionState.mode === 'move') {
                const zoneRect = zone.getBoundingClientRect();
                const maxX = metrics.widthPx - zoneRect.width;
                const maxY = metrics.heightPx - zoneRect.height;

                let xPx = event.clientX - paperRect.left - interactionState.offsetX;
                let yPx = event.clientY - paperRect.top - interactionState.offsetY;
                xPx = Math.max(0, Math.min(maxX, xPx));
                yPx = Math.max(0, Math.min(maxY, yPx));

                let xMm = pxToMmX(xPx, metrics);
                let yMm = pxToMmY(yPx, metrics);

                const snappedToZones = snapMoveToZones(
                    xMm,
                    yMm,
                    readField(zone.dataset.w),
                    readField(zone.dataset.h),
                    zone
                );
                xMm = snappedToZones.xMm;
                yMm = snappedToZones.yMm;

                xMm = snapValue(xMm);
                yMm = snapValue(yMm);

                writeField(zone.dataset.x, xMm);
                writeField(zone.dataset.y, yMm);

                dragHint.textContent = zone.querySelector('.zone-label').textContent.trim() + ': X ' + xMm.toFixed(1) + ' mm, Y ' + yMm.toFixed(1) + ' mm';
            } else {
                const dx = event.clientX - interactionState.startMouseX;
                const dy = event.clientY - interactionState.startMouseY;

                let nextWidthPx = Math.max(20, interactionState.startWidth + dx);
                let nextHeightPx = Math.max(20, interactionState.startHeight + dy);

                const currentLeftPx = interactionState.startLeft - paperRect.left;
                const currentTopPx = interactionState.startTop - paperRect.top;

                nextWidthPx = Math.min(nextWidthPx, metrics.widthPx - Math.max(0, currentLeftPx));
                nextHeightPx = Math.min(nextHeightPx, metrics.heightPx - Math.max(0, currentTopPx));

                let wMm = pxToMmX(nextWidthPx, metrics);
                let hMm = pxToMmY(nextHeightPx, metrics);

                const snappedResize = snapResizeToZones(
                    readField(zone.dataset.x),
                    readField(zone.dataset.y),
                    wMm,
                    hMm,
                    zone
                );
                wMm = snappedResize.wMm;
                hMm = snappedResize.hMm;

                wMm = snapValue(wMm);
                hMm = snapValue(hMm);

                writeField(zone.dataset.w, wMm);
                writeField(zone.dataset.h, hMm);

                dragHint.textContent = zone.querySelector('.zone-label').textContent.trim() + ': W ' + wMm.toFixed(1) + ' mm, H ' + hMm.toFixed(1) + ' mm';
            }
        });

        window.addEventListener('mouseup', () => {
            if (!interactionState) {
                return;
            }

            interactionState.zoneElement.classList.remove('active');
            interactionState = null;
            dragHint.textContent = 'Astuce: zone = deplacer, carre noir = redimensionner.';
        });

        [
            '{{ form.header_x.vars.id }}', '{{ form.header_y.vars.id }}', '{{ form.header_w.vars.id }}', '{{ form.header_h.vars.id }}',
            '{{ form.title_x.vars.id }}', '{{ form.title_y.vars.id }}', '{{ form.title_w.vars.id }}', '{{ form.title_h.vars.id }}',
            '{{ form.client_x.vars.id }}', '{{ form.client_y.vars.id }}', '{{ form.client_w.vars.id }}', '{{ form.client_h.vars.id }}',
            '{{ form.table_x.vars.id }}', '{{ form.table_y.vars.id }}', '{{ form.table_w.vars.id }}', '{{ form.table_h.vars.id }}',
            '{{ form.totals_x.vars.id }}', '{{ form.totals_y.vars.id }}', '{{ form.totals_w.vars.id }}', '{{ form.totals_h.vars.id }}',
            '{{ form.footer_x.vars.id }}', '{{ form.footer_y.vars.id }}', '{{ form.footer_w.vars.id }}', '{{ form.footer_h.vars.id }}',
            '{{ form.signature_x.vars.id }}', '{{ form.signature_y.vars.id }}', '{{ form.signature_w.vars.id }}', '{{ form.signature_h.vars.id }}'
        ].forEach((id) => {
            const input = document.getElementById(id);
            if (input) {
                input.addEventListener('input', refreshAllZones);
            }
        });

        if (snapEnabledInput) {
            snapEnabledInput.addEventListener('change', refreshAllZones);
        }

        if (snapStepInput) {
            snapStepInput.addEventListener('change', refreshAllZones);
        }

        window.addEventListener('resize', refreshAllZones);

        if (fileInput && bgImage) {
            fileInput.addEventListener('change', () => {
                const file = fileInput.files && fileInput.files[0] ? fileInput.files[0] : null;
                if (!file) {
                    return;
                }

                const objectUrl = URL.createObjectURL(file);
                bgImage.src = objectUrl;
                bgImage.classList.remove('d-none');
            });
        }

        document.querySelectorAll('input[data-sync]').forEach((rangeInput) => {
            const target = document.getElementById(rangeInput.dataset.sync);
            if (!target) {
                return;
            }

            rangeInput.value = target.value || target.min || '0';
            rangeInput.addEventListener('input', () => {
                target.value = parseFloat(rangeInput.value).toFixed(2);
                target.dispatchEvent(new Event('input', { bubbles: true }));
            });

            target.addEventListener('input', () => {
                rangeInput.value = target.value;
            });
        });

        refreshAllZones();
    </script>
