{{ form_start(form) }}
    {% set previewSrc = previewImagePath ? asset(previewImagePath) : '' %}
    <style>
        .anchor-card {
            border: 1px solid #e5e7eb;
            border-radius: 0.75rem;
            padding: 1rem;
            background: #fafafa;
        }

        .visual-editor {
            border: 1px solid #d1d5db;
            border-radius: 0.75rem;
            overflow: hidden;
            background: #f8fafc;
        }

        .visual-toolbar {
            border-bottom: 1px solid #e5e7eb;
            background: #ffffff;
            padding: 0.65rem 0.9rem;
            font-size: 0.9rem;
            color: #475569;
        }

        .paper {
            position: relative;
            width: 100%;
            max-width: 760px;
            margin: 0 auto;
            aspect-ratio: 210 / 297;
            background: #eef2f7;
            user-select: none;
        }

        .paper-bg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .paper-placeholder {
            position: absolute;
            inset: 0;
            background-image: repeating-linear-gradient(
                45deg,
                #f1f5f9,
                #f1f5f9 12px,
                #e2e8f0 12px,
                #e2e8f0 24px
            );
        }

        .snap-controls {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .drag-zone {
            position: absolute;
            min-width: 64px;
            min-height: 28px;
            border-radius: 0.45rem;
            border: 1px solid rgba(15, 23, 42, 0.38);
            background: rgba(255, 255, 255, 0.75);
            color: #0f172a;
            font-size: 0.78rem;
            font-weight: 600;
            cursor: move;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
            overflow: hidden;
            padding: 0.25rem 0.4rem;
        }

        .drag-zone.active {
            outline: 2px solid #2563eb;
            outline-offset: 1px;
        }

        .drag-header { border-left: 4px solid #2563eb; }
        .drag-title  { border-left: 4px solid #0d9488; }
        .drag-client { border-left: 4px solid #059669; }
        .drag-table  { border-left: 4px solid #ea580c; }
        .drag-totals { border-left: 4px solid #7c3aed; }
        .drag-footer { border-left: 4px solid #0891b2; }
        .drag-signature { border-left: 4px solid #ef4444; }

        .zone-label {
            pointer-events: none;
        }

        .resize-handle {
            position: absolute;
            right: 1px;
            bottom: 1px;
            width: 11px;
            height: 11px;
            border-radius: 2px;
            background: #0f172a;
            opacity: 0.75;
            cursor: nwse-resize;
        }

        .coords {
            color: #64748b;
            font-size: 0.8rem;
            margin-top: 0.3rem;
        }

        .anchor-title {
            font-weight: 600;
            margin-bottom: 0.75rem;
        }

        .anchor-range {
            margin-top: 0.25rem;
        }

        /* ── Dark mode overrides ─────────────────────────────────────── */
        [data-bs-theme="dark"] .anchor-card {
            border-color: #334155;
            background: #1e293b;
        }

        [data-bs-theme="dark"] .visual-editor {
            border-color: #334155;
            background: #0f172a;
        }

        [data-bs-theme="dark"] .visual-toolbar {
            border-color: #334155;
            background: #1e293b;
            color: #94a3b8;
        }

        [data-bs-theme="dark"] .paper {
            background: #0f172a;
        }

        [data-bs-theme="dark"] .paper-placeholder {
            background-image: repeating-linear-gradient(
                45deg,
                #1e293b,
                #1e293b 12px,
                #263043 12px,
                #263043 24px
            );
        }

        /* Keep drag handles light in dark mode for maximum visibility. */
        [data-bs-theme="dark"] .drag-zone {
            background: rgba(255, 255, 255, 0.82);
            color: #0f172a;
            border-color: rgba(15, 23, 42, 0.38);
        }

        [data-bs-theme="dark"] .resize-handle {
            background: #0f172a;
        }

        [data-bs-theme="dark"] .coords {
            color: #94a3b8;
        }

        [data-bs-theme="dark"] .anchor-title {
            color: #e2e8f0;
        }
    </style>

    <div class="row g-3">
        <div class="col-md-6">{{ form_row(form.name) }}</div>
        <div class="col-md-3">{{ form_row(form.documentType) }}</div>
        <div class="col-md-3 d-flex align-items-end">{{ form_row(form.isActive) }}</div>
        <div class="col-12">{{ form_row(form.imageFile) }}</div>
    </div>

    <hr>
    <h6 class="mb-3">Positionnement et dimension des zones (A4 portrait, en millimetres)</h6>
    <p class="text-muted mb-3">
        Deplacez chaque bloc avec la souris, redimensionnez via le coin en bas a droite, et activez Snap to grid pour un alignement propre.
    </p>

    <div class="visual-editor mb-4">
        <div class="visual-toolbar d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>Editeur visuel (deplacement + redimensionnement)</span>
            <div class="snap-controls">
                <div class="form-check m-0">
                    <input class="form-check-input" type="checkbox" id="snap-enabled" checked>
                    <label class="form-check-label" for="snap-enabled">Snap to grid</label>
                </div>
                <select class="form-select form-select-sm" id="snap-step" style="width: 100px;">
                    <option value="0.5">0.5 mm</option>
                    <option value="1" selected>1 mm</option>
                    <option value="2">2 mm</option>
                    <option value="5">5 mm</option>
                </select>
            </div>
            <span class="coords" id="drag-hint">Astuce: zone = deplacer, carre noir = redimensionner.</span>
        </div>

        <div id="paper" class="paper" data-width-mm="210" data-height-mm="297">
            {% if previewSrc %}
                <img id="paper-bg" class="paper-bg" src="{{ previewSrc }}" alt="Apercu theme PDF">
            {% else %}
                <div class="paper-placeholder"></div>
                <img id="paper-bg" class="paper-bg d-none" src="" alt="Apercu theme PDF">
            {% endif %}

            <div class="drag-zone drag-header" data-zone="header" data-x="{{ form.header_x.vars.id }}" data-y="{{ form.header_y.vars.id }}" data-w="{{ form.header_w.vars.id }}" data-h="{{ form.header_h.vars.id }}">
                <span class="zone-label">En-tete</span><span class="resize-handle"></span>
            </div>
            <div class="drag-zone drag-title" data-zone="title" data-x="{{ form.title_x.vars.id }}" data-y="{{ form.title_y.vars.id }}" data-w="{{ form.title_w.vars.id }}" data-h="{{ form.title_h.vars.id }}">
                <span class="zone-label">Titre</span><span class="resize-handle"></span>
            </div>
            <div class="drag-zone drag-client" data-zone="client" data-x="{{ form.client_x.vars.id }}" data-y="{{ form.client_y.vars.id }}" data-w="{{ form.client_w.vars.id }}" data-h="{{ form.client_h.vars.id }}">
                <span class="zone-label">Client</span><span class="resize-handle"></span>
            </div>
            <div class="drag-zone drag-table" data-zone="table" data-x="{{ form.table_x.vars.id }}" data-y="{{ form.table_y.vars.id }}" data-w="{{ form.table_w.vars.id }}" data-h="{{ form.table_h.vars.id }}">
                <span class="zone-label">Tableau</span><span class="resize-handle"></span>
            </div>
            <div class="drag-zone drag-totals" data-zone="totals" data-x="{{ form.totals_x.vars.id }}" data-y="{{ form.totals_y.vars.id }}" data-w="{{ form.totals_w.vars.id }}" data-h="{{ form.totals_h.vars.id }}">
                <span class="zone-label">Totaux</span><span class="resize-handle"></span>
            </div>
            <div class="drag-zone drag-footer" data-zone="footer" data-x="{{ form.footer_x.vars.id }}" data-y="{{ form.footer_y.vars.id }}" data-w="{{ form.footer_w.vars.id }}" data-h="{{ form.footer_h.vars.id }}">
                <span class="zone-label">Pied page</span><span class="resize-handle"></span>
            </div>
            <div class="drag-zone drag-signature" data-zone="signature" data-x="{{ form.signature_x.vars.id }}" data-y="{{ form.signature_y.vars.id }}" data-w="{{ form.signature_w.vars.id }}" data-h="{{ form.signature_h.vars.id }}">
                <span class="zone-label">Signature</span><span class="resize-handle"></span>
            </div>
        </div>
    </div>

