{% extends 'base.html.twig' %}

{% block title %}Thèmes PDF{% endblock %}

{% block body %}
<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0"><i class="bi bi-file-earmark-pdf"></i> Thèmes PDF</h1>
        <a href="{{ path('admin_pdf_theme_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nouveau thème
        </a>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nom</th>
                        <th>Type</th>
                        <th>Actif</th>
                        <th>Aperçu</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for theme in themes %}
                        <tr>
                            <td>{{ theme.name }}</td>
                            <td>
                                <span class="badge text-bg-secondary">
                                    {{ theme.documentType == 'DELIVERY' ? 'Bon de Livraison' : (theme.documentType == 'BOTH' ? 'Les deux' : 'Facture') }}
                                </span>
                            </td>
                            <td>
                                {% if theme.isActive %}
                                    <span class="badge bg-success">Actif</span>
                                {% else %}
                                    <span class="badge bg-warning text-dark">Inactif</span>
                                {% endif %}
                            </td>
                            <td>
                                <img src="{{ asset(theme.imagePath) }}" alt="{{ theme.name }}" style="max-height: 70px; border: 1px solid #ccc;">
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a href="{{ path('admin_pdf_theme_edit', {'id': theme.id}) }}" class="btn btn-outline-primary" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    {% if not theme.isActive %}
                                        <form method="post" action="{{ path('admin_pdf_theme_activate', {'id': theme.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('activate-pdf-theme-' ~ theme.id) }}">
                                            <button type="submit" class="btn btn-outline-success" title="Activer">
                                                <i class="bi bi-check2-circle"></i>
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('admin_pdf_theme_delete', {'id': theme.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce thème ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete-pdf-theme-' ~ theme.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Aucun thème PDF configuré.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
