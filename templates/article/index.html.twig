{% extends 'base.html.twig' %}

{% block title %}{{ 'article.title'|trans }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-box-seam"></i> {{ 'article.title'|trans }}</h1>
        {% if has_privilege('ARTICLE_MANAGE') %}
        <a href="{{ path('app_article_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> {{ 'article.new'|trans }}
        </a>
        {% endif %}
    </div>

    {# Search and Filter Form #}
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <label for="search" class="form-label">{{ 'common.search'|trans }}</label>
                    <input type="text" class="form-control" id="search" name="search" 
                           value="{{ search }}" placeholder="{{ 'article.search_placeholder'|trans }}">
                </div>
                <div class="col-md-4">
                    <label for="active" class="form-label">{{ 'common.status'|trans }}</label>
                    <select class="form-select" id="active" name="active">
                        <option value="all" {% if activeFilter == 'all' %}selected{% endif %}>{{ 'common.all'|trans }}</option>
                        <option value="active" {% if activeFilter == 'active' %}selected{% endif %}>{{ 'common.active_only'|trans }}</option>
                        <option value="inactive" {% if activeFilter == 'inactive' %}selected{% endif %}>{{ 'common.inactive_only'|trans }}</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-secondary w-100">
                        <i class="bi bi-search"></i> {{ 'common.filter'|trans }}
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# Articles Table #}
    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">{{ 'order.list_count'|trans({'%count%': articles|length}) }}</h5>
        </div>
        <div class="card-body p-0">
            {% if articles|length > 0 %}
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>{{ 'article.col_code'|trans }}</th>
                            <th>{{ 'article.col_designation'|trans }}</th>
                            <th class="text-center">{{ 'article.col_status'|trans }}</th>
                            <th class="text-center">{{ 'article.col_actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for article in articles %}
                        <tr>
                            <td><strong><code>{{ article.code }}</code></strong></td>
                            <td>{{ article.designation }}</td>
                            <td class="text-center">
                                {% if article.active %}
                                    <span class="badge bg-success">{{ 'common.active'|trans }}</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ 'common.inactive'|trans }}</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    {% if has_privilege('ARTICLE_MANAGE') %}
                                    <a href="{{ path('app_article_edit', {'id': article.id}) }}" 
                                       class="btn btn-outline-primary" title="{{ 'common.edit'|trans }}">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_article_toggle', {'id': article.id}) }}" 
                                          style="display: inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ article.id) }}">
                                        <button type="submit" class="btn btn-outline-warning" 
                                                title="{{ article.active ? 'common.inactive'|trans : 'common.active'|trans }}">
                                            <i class="bi bi-{{ article.active ? 'toggle-on' : 'toggle-off' }}"></i>
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('app_article_delete', {'id': article.id}) }}" 
                                          style="display: inline;"
                                          onsubmit="return confirm('{{ 'article.confirm_delete'|trans }}')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                                        <button type="submit" class="btn btn-outline-danger" title="{{ 'common.delete'|trans }}">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                    {% else %}
                                    <span class="text-muted">
                                        <i class="bi bi-eye"></i> {{ 'common.read_only'|trans }}
                                    </span>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="text-center py-5">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <p class="text-muted mt-3">{{ 'article.no_articles'|trans }}</p>
                {% if has_privilege('ARTICLE_MANAGE') %}
                <a href="{{ path('app_article_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> {{ 'article.create_first'|trans }}
                </a>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
