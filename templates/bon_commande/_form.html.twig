{{ form_start(form) }}
    {% if form_errors(form) %}
        <div class="alert alert-danger">
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-person-badge"></i> {{ 'common.client'|trans }}</h5>
        </div>
        <div class="card-body">
            {{ form_row(form.client) }}
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center bg-light">
            <h5 class="mb-0"><i class="bi bi-list-check"></i> {{ 'order.items_section'|trans }}</h5>
            <button type="button" class="btn btn-sm btn-primary" id="add-item-btn">
                <i class="bi bi-plus-circle"></i> {{ 'common.new'|trans }}
            </button>
        </div>
        <div class="card-body">
            <div id="order-items"
                 data-index="{{ form.bonCommandeItems|length }}"
                 data-prototype="{{ form_widget(form.bonCommandeItems.vars.prototype)|e('html_attr') }}">
                {% for itemForm in form.bonCommandeItems %}
                    <div class="order-item border rounded p-3 mb-3 bg-light-subtle">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-5">{{ form_row(itemForm.article) }}</div>
                            <div class="col-md-3">{{ form_row(itemForm.quantity) }}</div>
                            <div class="col-md-3">{{ form_row(itemForm.unit_price_snapshot) }}</div>
                            <div class="col-md-1">
                                <button type="button" class="btn btn-outline-danger remove-item-btn w-100" title="Supprimer la ligne">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {% if form.bonCommandeItems|length == 0 %}
                <p class="text-muted mb-0" id="empty-lines-hint">
                    {{ 'common.no_lines'|trans }}
                </p>
            {% endif %}
        </div>
    </div>

    {{ form_rest(form) }}

    <div class="d-flex gap-2">
        <button class="btn btn-primary" type="submit">
            <i class="bi bi-check-circle"></i> {{ button_label|default('common.save'|trans) }}
        </button>
        <a href="{{ path('app_bon_commande_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> {{ 'common.back_to_list'|trans }}
        </a>
    </div>
{{ form_end(form) }}

<script>
(function () {
    const container = document.getElementById('order-items');
    const addBtn = document.getElementById('add-item-btn');
    if (!container || !addBtn) {
        return;
    }

    function bindRemoveButtons(scope) {
        scope.querySelectorAll('.remove-item-btn').forEach((button) => {
            button.addEventListener('click', function () {
                const row = this.closest('.order-item');
                if (row) {
                    row.remove();
                }
            });
        });
    }

    addBtn.addEventListener('click', function () {
        const index = Number(container.dataset.index || 0);
        const prototype = container.dataset.prototype.replace(/__name__/g, index);
        const wrapper = document.createElement('div');
        wrapper.className = 'order-item border rounded p-3 mb-3 bg-light-subtle';
        wrapper.innerHTML = `
            <div class="row g-3 align-items-end">
                <div class="col-md-11">${prototype}</div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-outline-danger remove-item-btn w-100" title="Supprimer la ligne">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        `;

        container.appendChild(wrapper);
        container.dataset.index = String(index + 1);
        bindRemoveButtons(wrapper);

        const emptyHint = document.getElementById('empty-lines-hint');
        if (emptyHint) {
            emptyHint.remove();
        }
    });

    bindRemoveButtons(container);
})();
</script>
