{% extends 'base.html.twig' %}

{% block title %}{{ 'payment.title'|trans }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-credit-card"></i> {{ 'payment.title'|trans }}</h1>
        {% if has_privilege('PAYMENT_CREATE') %}
            <a href="{{ path('app_payment_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> {{ 'payment.new'|trans }}
            </a>
        {% endif %}
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="method" class="form-label">{{ 'common.method'|trans }}</label>
                    <select id="method" name="method" class="form-select">
                        <option value="all" {% if methodFilter == 'all' %}selected{% endif %}>{{ 'payment.method_all'|trans }}</option>
                        {% for code, label in methodChoices %}
                            <option value="{{ code }}" {% if methodFilter == code %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="date_from" class="form-label">{{ 'common.date_start'|trans }}</label>
                    <input type="date" id="date_from" name="date_from" value="{{ dateFrom }}" class="form-control">
                </div>
                <div class="col-md-3">
                    <label for="date_to" class="form-label">{{ 'common.date_end'|trans }}</label>
                    <input type="date" id="date_to" name="date_to" value="{{ dateTo }}" class="form-control">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-secondary w-100">
                        <i class="bi bi-search"></i> {{ 'common.filter'|trans }}
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">{{ 'order.list_count'|trans({'%count%': payments|length}) }}</h5>
        </div>
        <div class="card-body p-0">
            {% if payments|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>{{ 'payment.col_date'|trans }}</th>
                                <th>{{ 'payment.col_method'|trans }}</th>
                                <th>{{ 'payment.col_ref_internal'|trans }}</th>
                                <th>{{ 'payment.col_ref_external'|trans }}</th>
                                <th class="text-end">{{ 'payment.col_amount'|trans }}</th>
                                <th class="text-end">{{ 'payment.col_allocated'|trans }}</th>
                                <th class="text-center">{{ 'payment.col_invoices'|trans }}</th>
                                <th class="text-center">{{ 'payment.col_actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for payment in payments %}
                                <tr>
                                    <td>{{ payment.paymentDate|date('d/m/Y') }}</td>
                                    <td>
                                        {% if payment.method == 'CASH' %}{{ 'payment.method_cash'|trans }}
                                        {% elseif payment.method == 'CHEQUE' %}{{ 'payment.method_cheque'|trans }}
                                        {% elseif payment.method == 'VIREMENT' %}{{ 'payment.method_virement'|trans }}
                                        {% elseif payment.method == 'CARTE' %}{{ 'payment.method_carte'|trans }}
                                        {% else %}{{ payment.method }}{% endif %}
                                    </td>
                                    <td><strong>{{ payment.reference ?: '-' }}</strong></td>
                                    <td>{{ payment.externalReference ?: '-' }}</td>
                                    <td class="text-end fw-semibold">{{ payment.amount|number_format(3, '.', ' ') }} TND</td>
                                    <td class="text-end">{{ payment.totalAllocated|number_format(3, '.', ' ') }} TND</td>
                                    <td class="text-center">{{ payment.paymentFactures|length }}</td>
                                    <td class="text-center">
                                        <a href="{{ path('app_payment_show', {'id': payment.id}) }}" class="btn btn-outline-secondary btn-sm" title="{{ 'common.see_all'|trans }}">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <p class="text-muted mt-3">{{ 'payment.no_payments'|trans }}</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
