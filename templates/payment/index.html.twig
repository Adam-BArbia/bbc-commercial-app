{% extends 'base.html.twig' %}

{% block title %}Paiements{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-credit-card"></i> Paiements</h1>
        {% if has_privilege('PAYMENT_CREATE') %}
            <a href="{{ path('app_payment_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nouveau paiement
            </a>
        {% endif %}
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="method" class="form-label">Methode</label>
                    <select id="method" name="method" class="form-select">
                        <option value="all" {% if methodFilter == 'all' %}selected{% endif %}>Toutes</option>
                        {% for code, label in methodChoices %}
                            <option value="{{ code }}" {% if methodFilter == code %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="date_from" class="form-label">Date debut</label>
                    <input type="date" id="date_from" name="date_from" value="{{ dateFrom }}" class="form-control">
                </div>
                <div class="col-md-3">
                    <label for="date_to" class="form-label">Date fin</label>
                    <input type="date" id="date_to" name="date_to" value="{{ dateTo }}" class="form-control">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-secondary w-100">
                        <i class="bi bi-search"></i> Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">Liste ({{ payments|length }})</h5>
        </div>
        <div class="card-body p-0">
            {% if payments|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Methode</th>
                                <th>Ref interne</th>
                                <th>Ref externe</th>
                                <th class="text-end">Montant</th>
                                <th class="text-end">Alloue</th>
                                <th class="text-center">Factures</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for payment in payments %}
                                <tr>
                                    <td>{{ payment.paymentDate|date('d/m/Y') }}</td>
                                    <td>
                                        {% if payment.method == 'CASH' %}Especes
                                        {% elseif payment.method == 'CHEQUE' %}Cheque
                                        {% elseif payment.method == 'VIREMENT' %}Virement
                                        {% elseif payment.method == 'CARTE' %}Carte
                                        {% else %}{{ payment.method }}{% endif %}
                                    </td>
                                    <td><strong>{{ payment.reference ?: '-' }}</strong></td>
                                    <td>{{ payment.externalReference ?: '-' }}</td>
                                    <td class="text-end fw-semibold">{{ payment.amount|number_format(3, '.', ' ') }} TND</td>
                                    <td class="text-end">{{ payment.totalAllocated|number_format(3, '.', ' ') }} TND</td>
                                    <td class="text-center">{{ payment.paymentFactures|length }}</td>
                                    <td class="text-center">
                                        <a href="{{ path('app_payment_show', {'id': payment.id}) }}" class="btn btn-outline-secondary btn-sm" title="Voir">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <p class="text-muted mt-3">Aucun paiement trouve</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
