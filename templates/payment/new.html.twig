{% extends 'base.html.twig' %}

{% block title %}Nouveau paiement{% endblock %}

{% block body %}
<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-credit-card-2-front"></i> Enregistrer un paiement</h1>
        <a href="{{ path('app_payment_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour a la liste
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Informations paiement</h5>
        </div>
        <div class="card-body">
            <form method="post" id="payment-form">
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <label for="payment_date" class="form-label">Date de paiement</label>
                        <input type="date" id="payment_date" name="payment_date" class="form-control" value="{{ 'now'|date('Y-m-d') }}" required>
                    </div>
                    <div class="col-md-3">
                        <label for="method" class="form-label">Methode</label>
                        <select id="method" name="method" class="form-select" required>
                            <option value="">Selectionner...</option>
                            {% for code in methodChoices %}
                                <option value="{{ code }}">
                                    {% if code == 'CASH' %}Especes
                                    {% elseif code == 'CHEQUE' %}Cheque
                                    {% elseif code == 'VIREMENT' %}Virement
                                    {% elseif code == 'CARTE' %}Carte
                                    {% else %}{{ code }}{% endif %}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="external_reference" class="form-label">Reference externe (optionnel)</label>
                        <input type="text" id="external_reference" name="external_reference" class="form-control" placeholder="Ex: No cheque / ref virement">
                    </div>
                    <div class="col-md-3">
                        <label for="amount" class="form-label">Montant total (TND)</label>
                        <input type="number" id="amount" name="amount" class="form-control" min="0.001" step="0.001" required>
                    </div>
                </div>

                <div class="alert alert-info py-2">
                    <i class="bi bi-info-circle"></i> La reference interne paiement est generee automatiquement au format <strong>PAY-YYYY-XXXX</strong>.
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Facture</th>
                                <th>Client</th>
                                <th class="text-end">Total TTC</th>
                                <th class="text-end">Deja paye</th>
                                <th class="text-end">Reste a payer</th>
                                <th class="text-end" style="width: 180px;">Montant alloue</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for invoice in available_invoices %}
                                {% set firstDelivery = invoice.bonLivraisons|first %}
                                {% set order = firstDelivery and firstDelivery.bonCommande ? firstDelivery.bonCommande : null %}
                                {% set client = order ? order.client : null %}
                                {% set snapshot = invoice.clientSnapshot %}
                                {% set clientName = snapshot and snapshot.name is defined ? snapshot.name : (order ? order.clientSnapshot.name|default(client ? client.name : '-') : '-') %}
                                {% set remaining = invoice.remainingAmount %}
                                <tr>
                                    <td><strong>{{ invoice.reference }}</strong></td>
                                    <td>{{ clientName }}</td>
                                    <td class="text-end">{{ invoice.totalTtc|number_format(3, '.', ' ') }}</td>
                                    <td class="text-end">{{ invoice.totalPaid|number_format(3, '.', ' ') }}</td>
                                    <td class="text-end fw-semibold">{{ remaining|number_format(3, '.', ' ') }}</td>
                                    <td class="text-end">
                                        <input
                                            type="number"
                                            class="form-control form-control-sm text-end allocation-input"
                                            name="allocations[{{ invoice.id }}]"
                                            min="0"
                                            max="{{ remaining }}"
                                            step="0.001"
                                            placeholder="0.000"
                                        >
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        Aucune facture eligibile pour paiement.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Total allocations saisi: <strong id="allocated-total">0.000</strong> TND
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" {% if available_invoices|length == 0 %}disabled{% endif %}>
                            <i class="bi bi-check2-circle"></i> Enregistrer le paiement
                        </button>
                        <a href="{{ path('app_payment_index') }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const inputs = document.querySelectorAll('.allocation-input');
    const totalEl = document.getElementById('allocated-total');

    function refreshAllocatedTotal() {
        let total = 0;
        inputs.forEach(function (input) {
            total += parseFloat(input.value || '0');
        });
        totalEl.textContent = total.toFixed(3);
    }

    inputs.forEach(function (input) {
        input.addEventListener('input', refreshAllocatedTotal);
    });
});
</script>
{% endblock %}
